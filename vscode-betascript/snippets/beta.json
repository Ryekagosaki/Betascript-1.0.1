{
  "Print Statement": {
    "prefix": "teriak",
    "body": [
      "teriak(\"$1\");$0"
    ],
    "description": "Print to console in BetaScript"
  },
  "Variable Declaration": {
    "prefix": "ane",
    "body": [
      "ane $1 = $2;$0"
    ],
    "description": "Declare a variable"
  },
  "Constant Declaration": {
    "prefix": "tetep",
    "body": [
      "tetep $1 = $2;$0"
    ],
    "description": "Declare a constant"
  },
  "If Statement": {
    "prefix": "kalo",
    "body": [
      "kalo ($1) {",
      "\t$2",
      "}",
      "$0"
    ],
    "description": "If statement"
  },
  "If Else Statement": {
    "prefix": "udah_gituh",
    "body": [
      "kalo ($1) {",
      "\t$2",
      "} udah_gituh {",
      "\t$3",
      "}",
      "$0"
    ],
    "description": "If-else statement"
  },
  "Else If Statement": {
    "prefix": "kagaknye",
    "body": [
      "kalo ($1) {",
      "\t$2",
      "} kagaknye ($3) {",
      "\t$4",
      "}",
      "$0"
    ],
    "description": "Else-if statement"
  },
  "While Loop": {
    "prefix": "selagi",
    "body": [
      "selagi ($1) {",
      "\t$2",
      "}",
      "$0"
    ],
    "description": "While loop"
  },
  "For Loop": {
    "prefix": "itung",
    "body": [
      "itung (ane $1 = $2; $3; $4++) {",
      "\t$5",
      "}",
      "$0"
    ],
    "description": "For loop"
  },
  "Function Declaration": {
    "prefix": "bikin",
    "body": [
      "bikin $1($2) {",
      "\t$3",
      "}",
      "$0"
    ],
    "description": "Function declaration"
  },
  "Async Function": {
    "prefix": "nanti",
    "body": [
      "nanti bikin $1($2) {",
      "\t$3",
      "}",
      "$0"
    ],
    "description": "Async function declaration"
  },
  "Return Statement": {
    "prefix": "kasoh",
    "body": [
      "kasoh $1;$0"
    ],
    "description": "Return or export statement"
  },
  "Class Declaration": {
    "prefix": "cetak",
    "body": [
      "cetak $1 {",
      "\tmula($2) {",
      "\t\t$3",
      "\t}",
      "}",
      "$0"
    ],
    "description": "Class declaration"
  },
  "Constructor": {
    "prefix": "mula",
    "body": [
      "mula($1) {",
      "\t$2",
      "}",
      "$0"
    ],
    "description": "Constructor method"
  },
  "Try Catch": {
    "prefix": "cobi",
    "body": [
      "cobi {",
      "\t$1",
      "} tangkep ($2) {",
      "\t$3",
      "}",
      "$0"
    ],
    "description": "Try-catch block"
  },
  "Import Statement": {
    "prefix": "ambil",
    "body": [
      "ambil $1 dari \"$2\";$0"
    ],
    "description": "Import statement"
  },
  "Switch Statement": {
    "prefix": "pilih",
    "body": [
      "pilih ($1) {",
      "\tkalo_gini $2:",
      "\t\t$3",
      "\tbodo_amat:",
      "\t\t$4",
      "}",
      "$0"
    ],
    "description": "Switch statement"
  },
  "True Literal": {
    "prefix": "betoel",
    "body": ["betoel"],
    "description": "True boolean literal"
  },
  "False Literal": {
    "prefix": "kaga",
    "body": ["kaga"],
    "description": "False boolean literal"
  }
}
