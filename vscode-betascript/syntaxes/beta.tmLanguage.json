{
  "scopeName": "source.beta",
  "name": "BetaScript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.beta",
          "match": "//.*$"
        },
        {
          "name": "comment.block.beta",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.beta",
          "match": "\\b(ane|ente|tetep|betoel|kaga|kosong|entah)\\b"
        },
        {
          "name": "keyword.type.beta",
          "match": "\\b(angka|kata|tungguin|teriak|bisik|dengerin|sebrapa|ape|itungan|omongan|kumpulin|acak|tidur)\\b"
        },
        {
          "name": "keyword.control.flow.beta",
          "match": "\\b(kalo|kagaknye|udah_gituh|selagi|itung|saban|dalem|dah|lanjut)\\b"
        },
        {
          "name": "keyword.control.select.beta",
          "match": "\\b(pilih|kalo_gini|bodo_amat)\\b"
        },
        {
          "name": "keyword.function.beta",
          "match": "\\b(bikin|kasoh|sabut|nanti)\\b"
        },
        {
          "name": "keyword.class.beta",
          "match": "\\b(cetak|turun|ikut|mula|gua|punye|babang|anyar)\\b"
        },
        {
          "name": "keyword.modifier.beta",
          "match": "\\b(diem|statik)\\b"
        },
        {
          "name": "keyword.exception.beta",
          "match": "\\b(cobi|tangkep|akhirnye|lempar)\\b"
        },
        {
          "name": "keyword.module.beta",
          "match": "\\b(ambil|kasoh|dari)\\b"
        },
        {
          "name": "keyword.interface.beta",
          "match": "\\b(antarmuka)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.beta",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "include": "#escaped_characters"
            }
          ]
        },
        {
          "name": "string.quoted.single.beta",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "include": "#escaped_characters"
            }
          ]
        }
      ]
    },
    "escaped_characters": {
      "patterns": [
        {
          "name": "constant.character.escape.beta",
          "match": "\\\\(x[0-9A-Fa-f]{2}|[0-7]{3}|.)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.beta",
          "match": "\\b\\d+(_\\d+)?(\\.\\d+(_\\d+)?)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.beta",
          "match": "(\\+\\+|\\--|\\*\\*?|/|%|\\+|-|\\*|\\/)"
        },
        {
          "name": "keyword.operator.assignment.beta",
          "match": "(=\\s*(=\\s*)?|\\+=|\\-=|\\*=?|/=?)"
        },
        {
          "name": "keyword.operator.comparison.beta",
          "match": "(===|!==|==?|!=?|<=?|>=?)"
        },
        {
          "name": "keyword.operator.logical.beta",
          "match": "(&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.other.beta",
          "match": "(!|→)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.beta",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["beta", "bet"]
}
