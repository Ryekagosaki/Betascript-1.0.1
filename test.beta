// ==========================================
// 🔄 BETASCRIPT: DEMO LOOP (PERULANGAN) LENGKAP
// ==========================================

teriak("🔥 === 1. LOOP ITUNG (For Loop) ===")
// Hitung mundur dari 5 ke 1
itung (ane i = 5; i > 0; i--) {
    teriak("Hitungan mundur: " + i)
}
teriak("🎉 BOOM! Tahun Baru!")


teriak("\n🔥 === 2. LOOP SELAGI (While Loop) + DAH (Break) ===")
// Nembak sampe peluru habis
ane peluru = 3
selagi (peluru > 0) {
    teriak("DOR! Sisa peluru: " + peluru)
    peluru--
    
    kalo (peluru == 0) {
        teriak("Yah, peluru abis bang! Cabut dulu ah...")
        dah // Keluar dari loop paksa (Break)
    }
}


teriak("\n🔥 === 3. LOOP SABAN (For...of Array) + LANJUT (Continue) ===")
// Keliling Jakarta nyari jajanan khas Betawi
ane jajanan = deret["Kerak Telor", "Kue Pancong", "Dodol Betawi", "Soto Betawi", "Bir Pletok"]

saban (ane makanan dari jajanan) {
    // Skip Soto Betawi karena lagi pengen yang ringan-ringan
    kalo (makanan == "Soto Betawi") {
        teriak("Wah, " + makanan + " mah berat, skip dulu bang!")
        lanjut // Lewati iterasi ini (Continue)
    }
    teriak("Nyam nyam, lagi makan: " + makanan)
}


teriak("\n🔥 === 4. LOOP KERJAIN-SELAGI (Do-While) ===")
// Tebak angka, minimal jalan 1 kali
ane tebakan = 0
kerjain {
    tebakan++
    teriak("Ngecek angka: " + tebakan)
} selagi (tebakan < 3)

teriak("\n✅ Beres bang! Semua loop jalan mulus kagak ada error!")

